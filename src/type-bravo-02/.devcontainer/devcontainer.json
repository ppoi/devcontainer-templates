{
  "name": "type-bravo",
  "image": "ghcr.io/ppoi/devcontainer-images/type-bravo:latest",
  "features": {
    "./configure": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.vscode-quarkus",
        "vscjava.vscode-maven",
        "redhat.vscode-yaml",
        "redhat.vscode-xml"
      ],
      "settings": {
        "files.encoding": "utf8",
        "files.eol": "\r\n",
        "editor.useTabStops": false
      }
    }
  }
}