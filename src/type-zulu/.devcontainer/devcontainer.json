{
  "name": "type-zulu",
  "image": "ghcr.io/ppoi/devcontainer-images/base:latest",
  "containerUser": "vscode",
  "features": {
    "./configure": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "files.encoding": "utf8",
        "files.eol": "\r\n",
        "editor.useTabStops": false
      }
    }
  }
}